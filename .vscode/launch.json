{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Debug (LLDB)",
            "type": "lldb",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "CMake: Build",
            "terminal": "integrated",
            "sourceLanguages": [
                "cpp"
            ]
        },
        {
            "name": "Debug with Arguments",
            "type": "lldb",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",
            "args": "${command:extension.commandvariable.promptString}",
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "CMake: Build",
            "terminal": "integrated"
        },
        {
            "name": "Attach to Process",
            "type": "lldb",
            "request": "attach",
            "program": "${command:cmake.launchTargetPath}",
            "processId": "${command:pickProcess}"
        }
    ]
}
